#!/usr/bin/env python3
"""
Dead Box Harvester (dbh) - Quick launcher
Run 'dbh' from any directory to start credential harvesting.
"""

import sys
import os
from pathlib import Path

# Add current directory to path so we can import the harvester
sys.path.insert(0, os.getcwd())

def main():
    print("=" * 60)
    print("  Dead Box Harvester")
    print("=" * 60)
    print()
    
    # Query user for path
    cwd = os.getcwd()
    response = input(f"Use current directory as backup path?\n  [{cwd}]\n\n(y)es / (n)o: ").strip().lower()
    
    if response in ('y', 'yes', ''):
        backup_path = Path(cwd)
        print(f"\nUsing: {backup_path}")
    else:
        # Ask for specific path
        while True:
            custom_path = input("\nEnter path to Windows backup: ").strip()
            if custom_path:
                backup_path = Path(custom_path)
                if backup_path.exists():
                    break
                print(f"Path does not exist: {backup_path}")
            print("Please enter a valid path.")
    
    # Check if harvester module exists
    try:
        from dead_box_harvester.core.config import HarvesterConfig
        from dead_box_harvester.harvester import DeadBoxCredentialHarvester
        from dead_box_harvester.core.logger import setup_logger
    except ImportError as e:
        print(f"\nError: Cannot import harvester module: {e}")
        print("\nMake sure you're running from the dead-box-harvester directory,")
        print("or that the package is installed.")
        sys.exit(1)
    
    # Optional: ask for password
    print("\nOptional: Enter user password for DPAPI decryption")
    print("  (press Enter to skip)")
    password = input("Password: ").strip() or None
    
    # Optional: hashcat format
    hashcat = input("\nExport in hashcat format? (y/n): ").strip().lower() == 'y'
    
    # Optional: verbose
    verbose = input("Enable verbose output? (y/n): ").strip().lower() == 'y'
    
    # Create config and run
    try:
        config = HarvesterConfig(
            backup_path=backup_path,
            user_password=password,
            output_dir=Path("./harvester_output"),
            hashcat_format=hashcat,
            verbose=verbose,
            enable_pii_scan=True,
            enable_browser_extraction=True,
            enable_wifi_extraction=True,
            enable_credential_manager=True
        )
        
        print("\n" + "=" * 60)
        print("Starting harvest...")
        print("=" * 60 + "\n")
        
        harvester = DeadBoxCredentialHarvester(config)
        success = harvester.run()
        
        if success:
            print("\n" + "=" * 60)
            print("Harvest complete! Results in ./harvester_output/")
            print("=" * 60)
            sys.exit(0)
        else:
            print("\nHarvest failed. Check errors above.")
            sys.exit(1)
            
    except Exception as e:
        print(f"\nError: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()